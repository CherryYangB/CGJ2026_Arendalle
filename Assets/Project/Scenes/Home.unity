  aboutGroup: {fileID: 1937208268}
  whiteFade: {fileID: 1492415978}
  transitionTextGroup: {fileID: 1900200004}
  transitionText: {fileID: 1900200003}
  transitionMessage: "\u201CI feel as if I'm losing all my leaves... the branches,
    and the wind, and the rain. I have nowhere to put my head down anymore.\u201D\n\u201C\u6211\u611F\u89C9\u81EA\u5DF1\u6B63\u5728\u4E00\u7247\u7247\u51CB\u96F6\u2026\u2026\u90A3\u4E9B\u6811\u679D\uFF0C\u8FD8\u6709\u98CE\u548C\u96E8\u3002\u6211\u518D\u4E5F\u6CA1\u6709\u6816\u8EAB\u4E4B\u5730\u4E86\u3002\u201D\n--\u300A\u56F0\u5728\u65F6\u95F4\u7684\u7236\u4EB2\u300B\uFF08The
    Father\uFF0C2020\uFF09"
  transitionMessage2: "\u603B\u89C9\u5F97\u81EA\u5DF1\u5FD8\u8BB0\u4E86\u4EC0\u4E48\u91CD\u8981\u7684\u4E8B\u3002\u3002\u3002\uFF1F"
  sceneFadeDuration: 1.15
  transitionTextHoldDuration: 3
  transitionTextFadeOutDuration: 0.75
  aboutFadeDuration: 0.9
  defaultFont: {fileID: 12800000, guid: 526a8a54cf7aa409c88829b56635b1b6, type: 3}
  transitionMessageFontSize: 40
  preferredFontNames: []
